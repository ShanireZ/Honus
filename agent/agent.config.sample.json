{
  // 身份:每机固定。examId/seatId **不再配置** —— examId 由服务端派发(当前活跃考试),
  // seatId 由 OIDC 身份派生(cpplearn username)。psk(legacy)模式才需要手工补 examId/seatId。
  "agentId": "ag-PC01",
  "machineId": "PC-01",

  "serverWsBase": "ws://192.168.1.10:8080",
  "serverHttpBase": "http://192.168.1.10:8080",

  // 采集鉴权:oidc(推荐·启动后待命,开考弹浏览器登录 cpplearn 换会话) | psk(legacy·须另配 psk/examId/seatId)
  "authMode": "oidc",
  "oidcIssuer": "https://betaoi.cc",
  "oidcClientId": "horus-client",

  "targetHeight": 1080,
  "webpQuality": 75,
  "baselineMinSeconds": 30,
  "baselineMaxSeconds": 90,

  "largePasteThreshold": 200,

  "whitelistHosts": ["judge.exam.lan", "oj.school.lan"],
  "whitelistProcs": ["code", "devenv", "cl", "g++", "gcc", "mingw32-make", "explorer", "horus.agent"]
}
